# --- Application ---
APP_NAME=Reelmap                 # Display name used in mail, notifications, admin
APP_ENV=local                    # local | staging | production
APP_KEY=                         # Set via `php artisan key:generate`
APP_DEBUG=true                   # NEVER true in production (leaks stack traces)
APP_URL=http://localhost         # Base URL; used for signed URLs and links

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file      # Where maintenance-mode flag lives
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12                 # Password hashing cost

# --- Logging ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (Postgres + PostGIS) ---
DB_CONNECTION=pgsql              # PostGIS-enabled Postgres (see docker-compose.yml)
DB_HOST=pgsql                    # Sail service hostname; use 127.0.0.1 with Herd
DB_PORT=5432
DB_DATABASE=reelmap
DB_USERNAME=sail                 # Sail default; change for Herd/production
DB_PASSWORD=password             # Sail default; change for Herd/production

# --- Session / Cache / Queue (Redis-backed) ---
SESSION_DRIVER=cookie            # Stateless API; cookie sessions only for web/admin
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local            # Overridden to R2/S3 media disk in T-009

QUEUE_CONNECTION=redis           # Horizon-managed queues (T-007)
CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis                 # Sail service hostname; 127.0.0.1 with Herd
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail (Mailpit in dev) ---
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit                # Sail Mailpit service; view at http://localhost:8025
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@reelmap.app"
MAIL_FROM_NAME="${APP_NAME}"

# --- Search (Meilisearch, wired in T-031) ---
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700   # Sail service; 127.0.0.1:7700 with Herd
MEILISEARCH_KEY=                           # Master key; required outside local

# --- Media storage (T-009) ---
# Dev default is the local fallback (no R2 account needed): local_media /
# local_media_originals under storage/app/media. In staging/prod set:
#   MEDIA_DISK=media   MEDIA_ORIGINALS_DISK=media_originals
MEDIA_DISK=local_media
MEDIA_ORIGINALS_DISK=local_media_originals
MEDIA_GET_URL_TTL=30             # signed read-URL lifetime (minutes)
MEDIA_PUT_URL_TTL=15             # signed upload-URL lifetime (minutes)

# Post-image ingestion (T-013): a photo/carousel post with no video has its
# images pulled and stored as keyframes so the model can see them.
MEDIA_MAX_IMAGE_BYTES=26214400   # per-image download cap (bytes; 25 MiB)
MEDIA_VERIFY_IMAGE_HOST=true     # SSRF guard: resolve + reject private/reserved
                                 # image hosts. Keep true everywhere except the
                                 # no-network test env (phpunit sets it false).

# Cloudflare R2 (S3 API) — only used when MEDIA_DISK=media. Keys live in the
# secret manager in prod (NFR-8); never commit real values.
MEDIA_ACCESS_KEY_ID=             # R2 access key id
MEDIA_SECRET_ACCESS_KEY=         # R2 secret
MEDIA_REGION=auto                # `auto` for R2 (or us-east-1)
MEDIA_BUCKET=                    # reelmap-staging / reelmap-prod
MEDIA_ENDPOINT=                  # https://<account>.r2.cloudflarestorage.com

# --- Instagram carousel images (InstagramApiResolver, T-013) ---
# Reads EVERY slide of a photo/carousel post (the menu shots) via Instagram's
# web media API. Needs a Netscape cookies.txt exported from a logged-in browser
# (at least `sessionid`); without it the resolver is a no-op and only the oEmbed
# hero image is ingested. Path is inside the container (Sail mounts apps/api at
# /var/www/html); storage/app is gitignored, so keep the file there.
INGESTION_IG_API_ENABLED=true
INGESTION_IG_COOKIES_PATH=       # e.g. /var/www/html/storage/app/ig-cookies.txt
INGESTION_IG_API_TIMEOUT=15      # media API request timeout (seconds)

# yt-dlp video adapter (T-074): downloads a post's real video so the pipeline
# gets scene keyframes + audio, not just the caption. dev.sh drops the binary
# into the container on boot; PROD must bake yt-dlp into the worker image/host
# (T-055). COOKIES defaults to INGESTION_IG_COOKIES_PATH and is only needed for
# private/rate-limited posts. Set INGESTION_YTDLP_ENABLED=false to force the
# caption-only path.
INGESTION_YTDLP_ENABLED=true
INGESTION_YTDLP_BIN=yt-dlp        # binary name or absolute path
INGESTION_YTDLP_TIMEOUT=120       # download timeout (seconds)
# Left commented so the key stays ABSENT and the config default fires: env(key,
# default) only falls back when the key is unset — a bare `KEY=` is '' and would
# disable the INGESTION_IG_COOKIES_PATH fallback. Uncomment only to override it.
# INGESTION_YTDLP_COOKIES_PATH=

# --- Generic AWS/S3 (Laravel's stock s3 disk; unused by the media pipeline) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- AI model routing (T-019/T-020) ---
# --- AI extraction (ModelRouter, T-019) ---
OLLAMA_URL=http://host.docker.internal:11434   # Local Ollama host reachable from Sail workers
OLLAMA_VISION_MODEL=qwen2.5-vl:7b   # Multimodal model for keyframes + text
OLLAMA_TEXT_MODEL=qwen2.5:14b       # Text-only pass when a share has no keyframes
OLLAMA_TIMEOUT=180                  # Generation timeout (seconds)
OLLAMA_KEEP_ALIVE=30m               # Keep the model resident between pipeline steps (avoids cold-reload timeouts)
OLLAMA_HEALTH_TIMEOUT=2             # Health probe timeout (seconds)
OLLAMA_HEALTH_CACHE_SECONDS=30      # Cache the health result this long
OLLAMA_CONNECT_TIMEOUT=5            # Connect timeout so a dead host fails fast
OPENROUTER_API_KEY=              # Fallback hosted vision/chat models via OpenRouter (T-020)
OPENROUTER_DEFAULT_MODEL=google/gemini-2.0-flash-001   # Default remote fallback model
AI_MAX_COST_PER_RUN=0.10         # Per-run USD cost cap
AI_DAILY_USER_BUDGET=0.50        # Per-user daily USD spend cap
AI_MIN_PUBLISH_CONFIDENCE=0.75   # Auto-publish floor; lower (e.g. 0.5) for a small local model in the demo
AI_TRANSLATE_TAGS=false          # ADR-084 #4: auto-translate new non-dish tags to name_i18n (needs OPENROUTER_API_KEY)

# --- Geocoding (T-022 / demo) ---
GOOGLE_PLACES_API_KEY=           # Google Places lookups for ResolvePlace; blank → keyless Nominatim
GEOCODER_DRIVER=auto             # auto|google|nominatim — auto uses Google when keyed, else Nominatim
NOMINATIM_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT="Reelmap/1.0 (self-hosted demo)"   # Required by Nominatim's usage policy

# Instagram-profile address fallback (T-075): when the geocoder can't place a
# venue but the caption named it by an @handle, mine that IG profile (business
# address / bio 📍 locality / full_name) and re-resolve. Reuses the IG session
# cookie above (INGESTION_IG_COOKIES_PATH). Set false to keep geocode_failed→review.
PLACES_IG_PROFILE_ENABLED=true

# --- Transcription (T-018) ---
TRANSCRIBER_DRIVER=whisper_cpp   # Local-first speech-to-text driver
WHISPER_BIN=whisper-cli          # whisper.cpp CLI (on PATH or absolute)
WHISPER_MODELS_DIR=              # Dir holding ggml-*.bin models (defaults to storage/whisper)
WHISPER_MODEL=ggml-base          # Model file basename (without .bin)
TRANSCRIPTION_HOSTED_ENABLED=false  # Sends user audio to a 3rd party — enable in prod only
TRANSCRIPTION_HOSTED_URL=https://api.openai.com/v1  # OpenAI-compatible base URL
TRANSCRIPTION_HOSTED_API_KEY=    # Hosted fallback API key
TRANSCRIPTION_HOSTED_MODEL=whisper-1

VITE_APP_NAME="${APP_NAME}"
