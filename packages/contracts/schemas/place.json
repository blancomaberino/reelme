{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://contracts.reelmap.app/schemas/place.json",
  "title": "PlaceDetail",
  "description": "GET /api/v1/places/{slug} data payload (T-030, 03 §2.6). `sources` appears only with ?include=sources (place-source.json items); `offers` only with ?include=offers (empty until M4). `my_tags` appears only for the authed owner (T-064) — the caller's private per-user labels, never present for guests or other users.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id", "name", "slug", "status", "lat", "lng", "category", "price_range",
    "city", "country_code", "address", "google_place_id", "opening_hours",
    "phone", "website", "cuisines", "vibe_tags", "dietary_tags", "dishes",
    "dishes_updated_at", "dishes_language", "source_count", "rating", "google_reviews",
    "discounts"
  ],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "slug": { "type": "string" },
    "status": { "type": "string", "enum": ["pending", "active"] },
    "lat": { "type": "number", "minimum": -90, "maximum": 90 },
    "lng": { "type": "number", "minimum": -180, "maximum": 180 },
    "category": { "type": ["string", "null"] },
    "price_range": { "type": ["integer", "null"], "minimum": 1, "maximum": 4 },
    "city": { "type": ["string", "null"] },
    "country_code": { "type": "string" },
    "address": { "type": "string" },
    "google_place_id": { "type": ["string", "null"] },
    "opening_hours": { "type": ["object", "array", "null"] },
    "phone": { "type": ["string", "null"] },
    "website": { "type": ["string", "null"] },
    "cuisines": { "type": "array", "items": { "type": "string" } },
    "vibe_tags": { "type": "array", "items": { "type": "string" } },
    "dietary_tags": { "type": "array", "items": { "type": "string" } },
    "dishes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "shown_in_video", "price"],
        "properties": {
          "name": { "type": "string" },
          "shown_in_video": { "type": "boolean" },
          "price": { "type": ["string", "null"] }
        }
      }
    },
    "dishes_updated_at": { "type": ["string", "null"], "description": "When the dish/menu list was last refreshed by a source (ISO 8601)." },
    "dishes_language": { "type": ["string", "null"], "description": "BCP-47 language of the menu source; dish names are kept verbatim in this language so the client can label it." },
    "source_count": { "type": "integer", "minimum": 0 },
    "rating": {
      "type": "object",
      "additionalProperties": false,
      "required": ["google", "app"],
      "properties": {
        "google": { "$ref": "#/definitions/ratingBlock" },
        "app": { "$ref": "#/definitions/ratingBlock" }
      }
    },
    "google_reviews": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "author": { "type": ["string", "null"] },
          "rating": { "type": ["number", "null"] },
          "text": { "type": ["string", "null"] },
          "relative_time": { "type": ["string", "null"] },
          "time": { "type": ["integer", "null"] },
          "profile_photo_url": { "type": ["string", "null"] }
        }
      }
    },
    "discounts": {
      "type": "array",
      "description": "Card/bank/wallet payment discounts mentioned across the place's sources (T-079), aggregated + deduped. `card` is the display label (resolved issuer, else scheme, else @handle); filter the map/index by it via ?card=.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["card", "terms", "percent"],
        "properties": {
          "card": { "type": "string", "description": "Display label of the paying card/bank/wallet." },
          "terms": { "type": "string", "description": "The benefit as stated, e.g. \"20% off\"." },
          "percent": { "type": ["integer", "null"], "minimum": 1, "maximum": 100 }
        }
      }
    },
    "sources": {
      "type": "array",
      "items": { "$ref": "place-source.json" }
    },
    "offers": { "type": "array" },
    "my_tags": {
      "type": "array",
      "description": "Owner-only private per-user tags (T-064). Present only when the caller is authenticated; absent for guests. Never contains another user's labels.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "created_at"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "created_at": { "type": ["string", "null"] }
        }
      }
    }
  },
  "definitions": {
    "ratingBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "count"],
      "properties": {
        "value": { "type": ["number", "null"], "minimum": 0, "maximum": 5 },
        "count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
